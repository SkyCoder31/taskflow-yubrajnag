# Copy to .env and fill in values before running docker compose up
# cp .env.example .env

# Required — no default. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable

# App
SERVER_PORT=8080
JWT_EXPIRY=24h
BCRYPT_COST=12
